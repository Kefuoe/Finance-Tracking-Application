appsettings.*.local.json
*.Development.local.json
.env
.env.*

# ---------- IDEs / editors ----------
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
.history/*

# ---------- OS ----------
.DS_Store
Thumbs.db
